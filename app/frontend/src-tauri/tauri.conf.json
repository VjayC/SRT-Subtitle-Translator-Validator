{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SRT Translator",
  "version": "1.3.0",
  "identifier": "com.srttranslator.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SRT Translator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/backend-0.0.1-SNAPSHOT.jar"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGOEIxNDg5NjJDMzcyNjEKUldSaGNzTmlpUlNMNzQwOCtrc2x3cEtIaHoyNzVJaW5RK3RnUEhKc21jUjE2KzNlcTZPaXF4Zk8K",
      "endpoints": [
        "https://github.com/VjayC/SRT-Subtitle-Translator-Validator/releases/latest/download/latest.json"
      ]
    }
  }
}